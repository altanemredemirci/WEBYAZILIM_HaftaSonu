
@{
    ViewData["Title"] = "About";
}

<div class="container mt-4">
    <h1>@ViewBag.Title</h1>
    <div class="alert alert-info">
        <h4>@ViewBag.Message</h4>
        <p>Toplam Kullanıcı: <strong>@ViewBag.UserCount</strong></p>

        @if (ViewBag.IsLoggedIn)
        {
            <p class="text-success">Giriş Yapıldı</p>
        }
        else
        {
            <p class="text-danger">Giriş Yapılmadı</p>
        }
    </div>
</div>

