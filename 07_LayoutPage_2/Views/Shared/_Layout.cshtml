<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Öğrenci Portalı</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" href="/">.NET Eğitimi</a>
                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" href="/">Ana Sayfa</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/About">Hakkımızda</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Contact">İletişim</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 mb-5" style="min-height: 400px;">
        <main role="main">
            @* İŞTE SİHRİN GERÇEKLEŞTİĞİ YER: Diğer View'lar buraya render edilecek *@
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3 mt-auto">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - Tasarım ve Geliştirme Uygulamaları
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>