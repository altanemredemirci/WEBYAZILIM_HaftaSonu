@model IEnumerable<StudentDisplayViewModel>

@{
    ViewData["Title"] = "Öğrenci Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-people-fill"></i> Öğrenci Listesi</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            + Yeni Öğrenci Ekle
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">#Id</th>
                            <th>Ad Soyad</th>
                            <th>İletişim Bilgileri</th>
                            <th>Yaş</th>
                            <th>Adres</th>
                            <th>Kayıt Tarihi</th>
                            <th>Durum</th>
                            <th class="text-center pe-3">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var student in Model)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-secondary">@student.Id</td>

                                    <td>
                                        <span class="fw-semibold">@student.FullName</span>
                                    </td>

                                    <td>
                                        <div class="text-primary text-decoration-none">@student.Email</div>
                                        <small class="text-muted">@student.PhoneNumber</small>
                                    </td>

                                    <td>@student.Age</td>

                                    <td>
                                        <span class="d-inline-block text-truncate" style="max-width: 150px;" title="@student.Address">
                                            @student.Address
                                        </span>
                                    </td>

                                    <td>@student.CreatedDateFormatted</td>

                                    <td>
                                        @if (student.StatusText == "Aktif" || student.StatusText == "Active")
                                        {
                                            <span class="badge bg-success">@student.StatusText</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@student.StatusText</span>
                                        }
                                    </td>

                                    <td class="text-center pe-3">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@student.Id" class="btn btn-outline-info" title="Detay">
                                                Görüntüle
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-outline-warning" title="Düzenle">
                                                Düzenle
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@student.Id" class="btn btn-outline-danger" title="Sil">
                                                Sil
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    <h5 class="fw-light">Kayıtlı öğrenci bulunmamaktadır.</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

